# Server
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://ezzeshop_user:ezzeshop_password_dev@localhost:5432/ezzeshop
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ezzeshop
DB_USER=ezzeshop_user
DB_PASSWORD=ezzeshop_password_dev
DB_SSL=false

# Redis
REDIS_URL=redis://:ezzeshop_redis_dev@localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production_min_64_chars
JWT_REFRESH_EXPIRES_IN=7d

# Anthropic AI
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=no-reply@ezzeshop.com
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=EzzeShop <no-reply@ezzeshop.com>

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# AWS S3 / Cloudflare R2 (storage de videos)
S3_BUCKET=ezzeshop-media
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_ENDPOINT=https://your-r2-endpoint.r2.cloudflarestorage.com

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=debug
